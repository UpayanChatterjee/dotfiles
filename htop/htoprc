# HTOP Color Configuration Template
# This template generates a custom htoprc configuration with themed colors
# Colors are defined using terminal color codes (0-255) or RGB hex values

# htoprc configuration with custom colors
fields=0 48 17 18 38 39 40 2 46 47 49 1
sort_key=46
sort_direction=-1
tree_sort_key=0
tree_sort_direction=1
hide_kernel_threads=1
hide_userland_threads=0
shadow_other_users=0
show_thread_names=0
show_program_path=1
highlight_base_name=0
highlight_deleted_exe=1
highlight_megabytes=1
highlight_threads=1
highlight_changes=0
highlight_changes_delay_secs=5
find_comm_in_cmdline=1
strip_exe_from_cmdline=1
show_merged_command=0
tree_view=0
tree_view_always_by_pid=0
all_branches_collapsed=0
header_margin=1
detailed_cpu_time=0
cpu_count_from_one=0
show_cpu_usage=1
show_cpu_frequency=0
show_cpu_temperature=0
degree_fahrenheit=0
update_process_names=0
account_guest_in_cpu_meter=0
color_scheme=6

# Custom color definitions using template variables
# Main interface colors
color_background=#0b0f0b
color_text=#e0e8dc
color_highlight=#aad0ac
color_selected=#151b15

# CPU meter colors (gradient)
color_cpu_low=#adf0b1
color_cpu_med=#e2f8d1
color_cpu_high=#c5b542

# Memory meter colors
color_mem_used=#66cfae
color_mem_buffers=#b0eec2
color_mem_cache=#82d8b1
color_mem_available=#adf0b1

# Process list colors
color_process_normal=#e0e8dc
color_process_running=#adf0b1
color_process_sleeping=#6f786e
color_process_zombie=#c5b542
color_process_stopped=#e2f8d1

# Header and border colors
color_header=#a5ada3
color_border=#6f786e
color_separator=#424a41

# Function key colors
color_function_key=#f6ffc0
color_function_desc=#e0e8dc

# Tree view colors
color_tree_line=#6f786e
color_tree_collapsed=#aad0ac
color_tree_expanded=#b8ccb6

# Load average colors
color_load_low=#adf0b1
color_load_med=#e2f8d1
color_load_high=#c5b542

# Priority colors
color_priority_high=#c5b542
color_priority_normal=#e0e8dc
color_priority_low=#6f786e

# Swap meter colors
color_swap_used=#c6c177
color_swap_cache=#bcd797

# Temperature colors (if enabled)
color_temp_cool=#adf0b1
color_temp_warm=#e2f8d1
color_temp_hot=#c5b542
