{
  "theme": {
    "postHook": "~/.config/caelestia/post-theme-hook.sh"
  },
  "toggles": {
    "communication": {
      "discord": {
        "enable": false
      },
      "whatsie": {
        "enable": false,
        "match": [
          {
            "class": "com.ktechpit.whatsie"
          }
        ],
        "command": [
          "whatsie"
        ],
        "move": true
      },
      "zapzap": {
        "enable": true,
        "match": [
          {
            "class": "com.rtosta.zapzap"
          }
        ],
        "command": [
          "zapzap"
        ],
        "move": true
      }
    },
    "books": {
      "readest": {
        "enable": true,
        "match": [
          {
            "title": "Readest"
          },
          {
            "class": "readest"
          }
        ],
        "command": [
          "readest"
        ],
        "move": true
      },
      "calibre": {
        "enable": false,
        "match": [
          {
            "class": "calibre-gui"
          },
          {
            "class": "calibre"
          }
        ],
        "command": [
          "calibre"
        ],
        "move": true
      }
    },
    "sysmon": {
      "plasma-systemmonitor": {
        "enable": true,
        "match": [
          {
            "class": "org.kde.plasma-systemmonitor",
            "title": "Overview — System Monitor"
          }
        ],
        "command": [
          "plasma-systemmonitor"
        ],
        "move": true
      }
    }
  }
}
