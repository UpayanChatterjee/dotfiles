[Unit]
Description=Persistent StatusNotifierHost for Caelestia
Documentation=file://%h/.config/quickshell/caelestia/TRAY_FIXES.md
After=graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStart=%h/.local/bin/caelestia-sni-host
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target
